# Öffentliche Basis-URL der Seite (für SEO, Sitemap, OpenGraph)
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# --- Später: echte Gaming-APIs (noch NICHT aktiv) ---
# Diese Werte werden erst gebraucht, wenn du in services/providers/*
# echte Quellen aktivierst. Mock-Daten brauchen nichts davon.
# IGDB (über Twitch): https://api-docs.igdb.com
# IGDB_CLIENT_ID=
# IGDB_CLIENT_SECRET=
# RAWG: https://rawg.io/apidocs
# RAWG_API_KEY=
# Steam: https://steamcommunity.com/dev
# STEAM_API_KEY=
